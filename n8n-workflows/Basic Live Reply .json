        "googleOAuth2Api": {
          "id": "4YodCAnvEGWKVPxO",
          "name": "Bourneken os"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $('👂 Fetch Chat').first().json.items; \n\nif (!items || items.length === 0) return [];\n\nconst MY_BOT_NAMES = ["YOUR_MAIN_BOT_NAME", "YOUR_SECOND_BOT_NAME", "@YOUR_MAIN_BOT_NAME"]; // ⚠️ เปลี่ยนชื่อบอทตรงนี้ให้ตรงกับชื่อช่อง YouTube ของบอท\n\nconst MAX_TIME_DIFF_MS = 90000; \nconst now = new Date().getTime();\nlet queue = [];\nconst seenAuthorsInThisBatch = new Set(); // 🛡️ ANTI-SPAM: กฎเหล็ก 1 คน / 1 ข้อความ / 1 รอบ\n\nfor (const msg of items) {\n  if (!msg.snippet || !msg.authorDetails) continue;\n  \n  const author = msg.authorDetails.displayName;\n  const msgTime = new Date(msg.snippet.publishedAt).getTime();\n  const text = msg.snippet.displayMessage;\n  \n  if (MY_BOT_NAMES.includes(author)) continue;\n  if (now - msgTime > MAX_TIME_DIFF_MS) continue;\n\n  // 🛑 SPAM BLOCKER: ถ้ายูสเซอร์คนนี้โผล่มาแล้วในรอบนี้ (แปลว่ากำลังสแปมรัวๆ) ดีดข้อความใหม่ทิ้งทันที!\n  if (seenAuthorsInThisBatch.has(author)) continue;\n  seenAuthorsInThisBatch.add(author);\n\n  queue.push({\n    messageId: msg.id,\n    author: author,\n    channelId: msg.authorDetails.channelId,\n    message: text,\n    publishedAt: msg.snippet.publishedAt,\n    liveChatId: msg.snippet.liveChatId\n  });\n}\n\n// 🚦 จัดคิว: ดึงแชทเก่าสุดขึ้นมาก่อน และจำกัดโควต้าคิวรวมที่ 3 ข้อความ\nqueue.reverse();\nreturn queue.slice(0, 3).map(q => ({ json: q }));"
      },
