    {
      "parameters": {
        "jsCode": "const now = new Date();\n\n// แปลงเวลาเป็นไทย\nconst thaiTime = new Date(\n  now.toLocaleString(\"en-US\", { timeZone: \"Asia/Bangkok\" })\n);\n\nconst hour = thaiTime.getHours();\nconst minute = thaiTime.getMinutes(); // ดึงค่านาทีมาด้วย\n\nlet shift = \"\";\nlet vibe = \"\";\n// ถ้านาทีมากกว่า 30 ให้ถือว่าเป็นช่วง \"ปิดสถานี\" ถ้าไม่ใช่คือ \"เปิดสถานี\"\nlet actionType = minute >= 30 ? \"ปิดสถานี\" : \"เปิดสถานี\"; \n\nif (hour >= 0 && hour < 4) {\n  shift = \"Midnight Deep Dive 🌑\";\n  vibe = \"ความเงียบ, การทบทวนตัวเอง, พื้นที่ปลอดภัยในความมืด\";\n} else if (hour >= 10 && hour < 14) {\n  shift = \"Daylight Focus ☀️\";\n  vibe = \"การเริ่มต้นใหม่, พลังงานในการทำงาน, การมีเพื่อนร่วมนั่งเงียบๆ\";\n} else if (hour >= 19 && hour < 22) {\n  shift = \"Evening Chill 🌆\";\n  vibe = \"การทิ้งความเหนื่อยล้า, บรรยากาศอบอุ่นหลังเลิกงาน, การพักผ่อน\";\n} else {\n  shift = \"OFFLINE 💤\";\n  vibe = \"สถานีหยุดพักการโคจรชั่วคราว\";\n}\n\nreturn [\n  {\n    json: { shift, vibe, hour, actionType } // ส่ง actionType ไปด้วย\n  }\n];"
      },
