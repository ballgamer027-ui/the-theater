    {
      "parameters": {
        "jsCode": "let raw = $json.output;\n\n// 1. สกัดแท็ก ```json และ ``` ที่ AI ชอบแถมมาทิ้งไป\nif (typeof raw === 'string') {\n    raw = raw.replace(/```json/gi, '').replace(/```/g, '').trim();\n}\n\nlet parsed;\ntry {\n  parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch(e) {\n  throw new Error('AI output not JSON (หลังจากพยายามตัด Markdown แล้ว)');\n}\n\n// 2. ดึงค่าจาก todayMode มาใส่แทน เพราะ AI ไม่ได้ส่ง description มา\nreturn [{\n    json: { \n        title: parsed.title, \n        description: parsed.todayMode \n    }\n}];"
      },
