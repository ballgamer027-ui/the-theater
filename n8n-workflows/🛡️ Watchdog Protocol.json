      "parameters": {
        "jsCode": "const raw = $json.output;\nlet parsed;\ntry {\n parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch(e) {\n throw new Error('AI output not JSON');\n}\nreturn [{json:{ title: parsed.title, description: parsed.description }}];"
