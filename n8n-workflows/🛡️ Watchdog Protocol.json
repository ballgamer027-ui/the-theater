    {
      "parameters": {
        "jsCode": "// ดึงชื่อคลิปเดิมจากโหนด YouTube\nconst currentTitle = $json.items[0]?.snippet?.title || \"\";\n\n// ใช้ Regex สกัดหาตัวเลขที่อยู่หลังคำว่า EP\nconst match = currentTitle.match(/EP\\s*(\\d+)/i);\nlet ep = parseInt(match ? match[1] : \"0\", 10);\n\n// บวก EP เพิ่มไป 1\nconst nextEP = isNaN(ep) ? 1 : ep + 1;\n\nreturn [{ \n  json: { \n    currentEP: nextEP, \n    oldTitle: currentTitle \n  } \n}];"
      },
